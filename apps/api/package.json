{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "prisma:pull:lovable": "prisma db pull --schema=prisma/lovable/schema.prisma",
    "prisma:pull:imersao": "prisma db pull --schema=prisma/imersao/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/lovable/schema.prisma && prisma generate --schema=prisma/imersao/schema.prisma",
    "prisma:generate:lovable": "prisma generate --schema=prisma/lovable/schema.prisma",
    "prisma:generate:imersao": "prisma generate --schema=prisma/imersao/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/throttler": "^6.1.1",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "nodemailer": "^6.9.15",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.16",
    "@types/passport-jwt": "^4.0.1",
    "@vercel/node": "^3.2.0",
    "prisma": "^5.18.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
