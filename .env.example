# ==========================================================================
# Variáveis raiz — copiar para .env e completar.
# Na Vercel, configurar como Environment Variables do projeto.
# ==========================================================================

# Banco antigo (compartilhado com o admin) — leitura geral e escrita em pf_imersoes_agendamento
# Params extras evitam ConnectionReset em conexões idle do Cloud SQL.
DATABASE_URL_LOVABLE="postgresql://lovable:CHANGEME@HOST:5432/liberdade-medica?schema=lovable&connection_limit=5&pool_timeout=20&connect_timeout=15"

# Banco novo (exclusivo deste app) — imersao_otp, email_log, access_log
DATABASE_URL_IMERSAO="postgresql://lovable:CHANGEME@HOST:5432/imersao-aluno?schema=public&connection_limit=5&pool_timeout=20&connect_timeout=15"

# JWT — gerar string aleatória 32+ chars, diferente do admin
JWT_SECRET="CHANGEME_PROD_USE_LONG_RANDOM_STRING"
JWT_EXPIRES_IN="30m"

# Cookie
COOKIE_DOMAIN="aluno.liberdademedicaedu.com.br"
COOKIE_SECURE="true"

# Gmail via OAuth2 (Workspace ou Gmail comum) — ver README para gerar refresh_token
GMAIL_USER="suprte@liberdademedicaedu.com.br"
GMAIL_OAUTH_CLIENT_ID="xxxxx.apps.googleusercontent.com"
GMAIL_OAUTH_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxx"
GMAIL_OAUTH_REFRESH_TOKEN="1//xxxxxxxxxxxxxxxxxxxxxxxxxx"
MAIL_FROM="Imersões LM <suprte@liberdademedicaedu.com.br>"

# CORS dev (não usado em prod, pois same-origin)
WEB_ORIGIN="http://localhost:5173"

# Frontend (Vite) — também precisam estar configuradas na Vercel
VITE_API_BASE_URL=""
VITE_CX_TELEFONE="(62) 98139-6751"
VITE_CX_WHATSAPP="5562981396751"

# Misc
NODE_ENV="development"
TZ="America/Sao_Paulo"
