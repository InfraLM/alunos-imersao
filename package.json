{
  "name": "imersao-ppg",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm --workspace api run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "echo '== root build start ==' && echo '== building web ==' && npm --workspace web run build && echo '== building api ==' && npm --workspace api run build && echo '== root build done =='",
    "build:web": "npm --workspace web run build",
    "build:api": "npm --workspace api run build",
    "prisma:pull:lovable": "npm --workspace api run prisma:pull:lovable",
    "prisma:pull:imersao": "npm --workspace api run prisma:pull:imersao",
    "prisma:generate": "npm --workspace api run prisma:generate"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  }
}
